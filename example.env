# ─── Public-facing URLs ────────────────────────────────────────────────────────
# Full URL to the Pangolin dashboard (no trailing slash)
PUBLIC_URL=https://pangolin.yourdomain.com
# Just the hostname portion (used in Traefik routing rules)
PANGOLIN_DOMAIN=pangolin.yourdomain.com
# Root domain (used by the CF bridge to scope DNS records)
BASE_DOMAIN=yourdomain.com

# ─── Let's Encrypt ─────────────────────────────────────────────────────────────
LETSENCRYPT_EMAIL=your-email@example.com

# ─── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Token from the Cloudflare Zero Trust dashboard → Networks → Tunnels
CF_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# ─── Cloudflare API ────────────────────────────────────────────────────────────
# API token with: Zone:DNS:Edit, Account:Cloudflare Tunnel:Edit
CF_API_TOKEN=your-cloudflare-api-token
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_TUNNEL_ID=your-cloudflare-tunnel-id
CF_ZONE_ID=your-cloudflare-zone-id
